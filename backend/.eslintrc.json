{
  "parserOptions": {
    "ecmaVersion": 2023,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2023": true
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "no-undef": "error",
    "prefer-const": "warn",
    "eqeqeq": ["warn", "smart"]
  },
  "ignorePatterns": ["node_modules/", "uploads/", "prisma/migrations/", "coverage/"]
}
