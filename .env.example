# ============================================
# GMAO Sakété-Ifangni — variables d'environnement
# Copier en .env et remplir les valeurs
# ============================================

# --- Environnement ---
NODE_ENV=development
PORT=10000

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql://user:password@localhost:5432/gmao_sakete
# DB test (pour vitest)
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/gmao_sakete_test

# --- Sécurité ---
# Générer: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changez-moi-secret-aleatoire-minimum-64-caracteres
JWT_EXPIRES_IN=7d

# --- Frontend ---
FRONTEND_URL=http://localhost:3000

# --- Dev uniquement: active /api/debug/* ---
ENABLE_DEBUG_ROUTES=false

# --- Cloudinary (upload images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Twilio (SMS alertes) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Email (Resend ou SMTP) ---
RESEND_API_KEY=
EMAIL_FROM=noreply@gmao-sakete.bj

# SMTP fallback (si pas Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# --- Logs ---
LOG_LEVEL=info

# --- Migrations au boot (forcer en dev) ---
RUN_MIGRATIONS=false
